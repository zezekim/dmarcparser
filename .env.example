# dmarc-parser secrets — copy to .env (chmod 600) and fill in.
# Only PARSER_DATABASE_URL and PARSER_API_KEYS are required; everything else
# has a sane default (see README "Configuration"). Placeholders only here.

# --- Core (required) -------------------------------------------------------
# Postgres DSN of the dmarc viewer database (host `db` on the dmarc_default network)
PARSER_DATABASE_URL=postgres://dmarc:CHANGE_ME@db:5432/dmarc?sslmode=disable

# API keys for /api/v1/*. Format: name=key=scopes (scopes: read|ingest|admin or *).
# A bare key (no =) means name "default" with all scopes. Generate a key with:
#   echo "dprs-$(openssl rand -hex 16)"
# Example (one read-only consumer, one ingest, one ops/all):
#   PARSER_API_KEYS=mxsentinel=dprs-CHANGE_ME=read,whmcs=dprs-CHANGE_ME=read|ingest,ops=dprs-CHANGE_ME=*
PARSER_API_KEYS=dprs-CHANGE_ME

# --- API tuning ------------------------------------------------------------
# Per-key requests/sec (token bucket, burst 3x); 0 disables rate limiting.
PARSER_RATE_LIMIT_RPS=10

# --- Webhooks --------------------------------------------------------------
# Comma-separated endpoints that receive signed JSON events (7 kinds).
# Legacy single-URL fallback: PARSER_WEBHOOK_URL.
PARSER_WEBHOOK_URLS=
PARSER_WEBHOOK_URL=
# HMAC-SHA256 signing secret (X-Parser-Signature). Share with webhook receivers
# (the viewer's /hooks/parser verifies against the same value).
PARSER_WEBHOOK_SECRET=

# --- Watchdog / alerting ---------------------------------------------------
PARSER_ALERT_URL=
PARSER_ALERT_SILENCE=36h
PARSER_ALERT_FAILED_SPIKE=10

# --- Anomaly / new-sender detection ---------------------------------------
PARSER_ANOMALY_SIGMA=3
PARSER_ANOMALY_MIN_FAILS=50
PARSER_NEWSENDER_MIN_MSGS=5

# --- Retention (0 = keep forever) -----------------------------------------
PARSER_RAW_XML_RETENTION=2160h
PARSER_MAIL_RETENTION=720h

# --- Enrichment / forensic -------------------------------------------------
PARSER_ENRICH_WORKERS=4
PARSER_RUF_REDACT=true

# --- Weekly email digest ---------------------------------------------------
PARSER_DIGEST_ENABLED=false
PARSER_DIGEST_SMTP_ADDR=mailserver:587
# Defaults to PARSER_IMAP_USER; password reuses the IMAP password.
PARSER_DIGEST_SMTP_USER=
PARSER_DIGEST_FROM=
PARSER_DIGEST_DAY=Monday
PARSER_DIGEST_HOUR=7

# --- Links -----------------------------------------------------------------
# Viewer base URL used for deep-links in digests/webhooks, e.g. https://dmarc.example.org
PARSER_VIEWER_URL=

# --- Storage / limits ------------------------------------------------------
PARSER_STORE_RAW_XML=true
PARSER_MAX_BODY_BYTES=67108864

# --- IMAP poller (optional; defaults shown) --------------------------------
# PARSER_IMAP_ADDR=mailserver:993        # empty string = API-only (poller off)
# PARSER_IMAP_USER=dmarc@example.org
# PARSER_IMAP_PASSWORD=                  # or PARSER_IMAP_PASSWORD_FILE
# PARSER_IMAP_TLS_SKIP_VERIFY=true       # mailserver cert is self-signed
# PARSER_POLL_INTERVAL=5m
